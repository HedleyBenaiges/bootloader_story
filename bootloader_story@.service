[Unit]
Description=Forced Boot Message Read
DefaultDependencies=no
After=local-fs.target
Before=display-manager.service

[Service]
Type=oneshot
StandardOutput=tty
StandardInput=tty
TTYPath=/dev/%I
ExecStart=/usr/local/bin/bootloader_story.sh
Conflicts=getty@%I.service

[Install]
WantedBy=sysinit.target
